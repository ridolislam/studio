
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores additional user information including their subscription and credits.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "credits": { "type": "number", "description": "Remaining request credits" },
        "totalRequests": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data stored by their Firebase Auth UID."
    }
  }
}
